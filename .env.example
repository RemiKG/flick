# ─────────────────────────────────────────────────────────────────────────────
# Flick — environment. Copy to `.env` and fill in. NOTHING here is committed.
# The app runs with ZERO of these set (honest offline mode); each value below
# turns on more of the real path the moment it exists.
# ─────────────────────────────────────────────────────────────────────────────

# The ONE thing that lights up the whole Qwen crew. A plain pay-as-you-go /
# free-tier key from https://home.qwencloud.com/api-keys (starts "sk-").
# Without it, Flick still runs — it samples the palette locally, animates a
# deterministic crayon preview, and says plainly the Qwen crew is dormant.
DASHSCOPE_API_KEY=

# Qwen Cloud base URLs (defaults are correct for the intl / Singapore region).
# OpenAI-compatible endpoint (chat, vision, images, embeddings):
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Native DashScope endpoint (async video synthesis, TTS, voice enrollment):
DASHSCOPE_NATIVE_URL=https://dashscope-intl.aliyuncs.com/api/v1

# The crew — model ids (override only if you want a different cast).
MODEL_READER=qwen3-vl-plus
MODEL_WRITER=qwen3.7-max
MODEL_STORYBOARDER=qwen3.7-plus
MODEL_PAINTER=wan2.6-t2i
MODEL_CAMERA=wan2.7-r2v
MODEL_CAMERA_FALLBACK=happyhorse-1.1-r2v
MODEL_CRITIC=qwen3-vl-plus
MODEL_VOICE=qwen3-tts-flash
MODEL_VOICE_FALLBACK=qwen3-tts-instruct-flash

# HTTP port (the deploy target — Alibaba Cloud ECS/SAS — sets this).
PORT=8080

# ── Optional: swap the filesystem Toy Box for a real database (env seam). ──
# Leave blank to use the built-in filesystem store (genuinely persistent).
# A Postgres URL (e.g. Alibaba Cloud RDS) activates the pg store automatically.
DATABASE_URL=

# ── Optional: keep downloaded media in Alibaba Cloud OSS instead of on disk. ──
# Qwen video URLs expire in ~24h, so Flick always downloads immediately; set
# these to push the durable copy to object storage instead of the local disk.
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
